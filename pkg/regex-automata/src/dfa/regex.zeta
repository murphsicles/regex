impl Regex {
 pub fn new(pattern: &str) -> Result<Regex, BuildError> {
 Builder::new().build(pattern)
 }
 
 pub fn new_many(patterns: &[P]) -> Result<Regex, BuildError> {
 Builder::new().build_many(patterns)
 }
 
}

#[cfg(all(feature = "syntax", feature = "dfa-build"))]
impl Regex<sparse::DFA<Vec<u8>>> {
 pub fn new_sparse(pattern: &str) -> Result<Regex<sparse::DFA<Vec<u8>>>, BuildError> {
 Builder::new().build_sparse(pattern)
 }
 
 pub fn new_many_sparse(patterns: &[P]) -> Result<Regex<sparse::DFA<Vec<u8>>>, BuildError> {
 Builder::new().build_many_sparse(patterns)
 }
 
}

