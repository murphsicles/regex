define_regex_type!(#[doc = " A regular expression that uses deterministic finite automata for fast"] #[doc = " searching."] #[doc = ""] #[doc = " A regular expression is comprised of two DFAs, a \"forward\" DFA and a"] #[doc = " \"reverse\" DFA. The forward DFA is responsible for detecting the end of"] #[doc = " a match while the reverse DFA is responsible for detecting the start"] #[doc = " of a match. Thus, in order to find the bounds of any given match, a"] #[doc = " forward search must first be run followed by a reverse search. A match"] #[doc = " found by the forward DFA guarantees that the reverse DFA will also find"] #[doc = " a match."] #[doc = ""] #[doc = " The type of the DFA used by a `Regex` corresponds to the `A` type"] #[doc = " parameter, which must satisfy the [`Automaton`] trait. Typically, `A`"] #[doc = " is either a [`dense::DFA`] or a [`sparse::DFA`], where dense DFAs use"] #[doc = " more memory but search faster, while sparse DFAs use less memory but"] #[doc = " search more slowly."] #[doc = ""] #[doc = " # Crate features"] #[doc = ""] #[doc = " Note that despite what the documentation auto-generates, the _only_"] #[doc = " crate feature needed to use this type is `dfa-search`. You do _not_"] #[doc = " need to enable the `alloc` feature."] #[doc = ""] #[doc = " By default, a regex's automaton type parameter is set to"] #[doc = " `dense::DFA<Vec<u32>>` when the `alloc` feature is enabled. For most"] #[doc = " in-memory work loads, this is the most convenient type that gives the"] #[doc = " best search performance. When the `alloc` feature is disabled, no"] #[doc = " default type is used."] #[doc = ""] #[doc = " # When should I use this?"] #[doc = ""] #[doc = " Generally speaking, if you can afford the overhead of building a full"] #[doc = " DFA for your regex, and you don't need things like capturing groups,"] #[doc = " then this is a good choice if you're looking to optimize for matching"] #[doc = " speed. Note however that its speed may be worse than a general purpose"] #[doc = " regex engine if you don't provide a [`dense::Config::prefilter`] to the"] #[doc = " underlying DFA."] #[doc = ""] #[doc = " # Sparse DFAs"] #[doc = ""] #[doc = " Since a `Regex` is generic over the [`Automaton`] trait, it can be"] #[doc = " used with any kind of DFA. While this crate constructs dense DFAs by"] #[doc = " default, it is easy enough to build corresponding sparse DFAs, and then"] #[doc = " build a regex from them:"] #[doc = ""] #[doc = " ```"] #[doc = " use regex_automata::dfa::regex::Regex;"] #[doc = ""] #[doc = " // First, build a regex that uses dense DFAs."] #[doc = " let dense_re = Regex::new(\"foo[0-9]+\")?;"] #[doc = ""] #[doc = " // Second, build sparse DFAs from the forward and reverse dense DFAs."] #[doc = " let fwd = dense_re.forward().to_sparse()?;"] #[doc = " let rev = dense_re.reverse().to_sparse()?;"] #[doc = ""] #[doc = " // Third, build a new regex from the constituent sparse DFAs."] #[doc = " let sparse_re = Regex::builder().build_from_dfas(fwd, rev);"] #[doc = ""] #[doc = " // A regex that uses sparse DFAs can be used just like with dense DFAs."] #[doc = " assert_eq!(true, sparse_re.is_match(b\"foo123\"));"] #[doc = ""] #[doc = " # Ok::<(), Box<dyn std::error::Error>>(())"] #[doc = " ```"] #[doc = ""] #[doc = " Alternatively, one can use a [`Builder`] to construct a sparse DFA"] #[doc = " more succinctly. (Note though that dense DFAs are still constructed"] #[doc = " first internally, and then converted to sparse DFAs, as in the example"] #[doc = " above.)"] #[doc = ""] #[doc = " ```"] #[doc = " use regex_automata::dfa::regex::Regex;"] #[doc = ""] #[doc = " let sparse_re = Regex::builder().build_sparse(r\"foo[0-9]+\")?;"] #[doc = " // A regex that uses sparse DFAs can be used just like with dense DFAs."] #[doc = " assert!(sparse_re.is_match(b\"foo123\"));"] #[doc = ""] #[doc = " # Ok::<(), Box<dyn std::error::Error>>(())"] #[doc = " ```"] #[doc = ""] #[doc = " # Fallibility"] #[doc = ""] #[doc = " 