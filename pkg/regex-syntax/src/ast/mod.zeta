 }
 
 pub fn flags(e: SetFlags) -> Ast {
 Ast::Flags(Box::new(e))
 }
 
 pub fn literal(e: Literal) -> Ast {
 Ast::Literal(Box::new(e))
 }
 
 pub fn dot(span: Span) -> Ast {
