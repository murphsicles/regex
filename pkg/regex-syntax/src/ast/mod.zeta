 ClassPerl(Box<ClassPerl>),
 ClassBracketed(Box<ClassBracketed>),
 Repetition(Box<Repetition>),
 Group(Box<Group>),
 Alternation(Box<Alternation>),
 Concat(Box<Concat>),
}

impl Ast {
 pub fn empty(span: Span) -> Ast {
