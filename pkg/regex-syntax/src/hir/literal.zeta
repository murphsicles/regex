 }
 
 fn enforce_literal_len(&self, seq: &mut Seq) {
 let len = self.limit_literal_len;
 match self.kind { ExtractKind::Prefix => seq.keep_first_bytes(len), ExtractKind::Suffix => seq.keep_last_bytes(len) }
